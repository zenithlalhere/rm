\begin{enumerate}
\item Let $x = (x_1, \cdots, x_n)$, where the $x_i$ are non negative real numbers. Set

$$ M_r(x) = \left( \frac{x_1^r + x_2^r+ \cdots+x_n^r}{n}\right) ^ \frac{1}{r} , r \in \textbf{R} \setminus 0,$$\\
and\\
$$M_0 (x) = (x_1 x_2 \cdots x_n)^\frac{1}{n}$$

We call $M_r(x)$ the $rth$ power mean of $x$.

Claim:
$$ \{ \lim_{r \to0} M_r(x) = M_0(x)$$


\item Define
$$ V_n = \left[
\begin{array}{ccccc}
1 & 1 & 1 & \cdots & 1 \\
x_1 & x_2 & x_3 & \cdots & x_n \\
x^2_1 & x^2_2 & x^2_3 & \cdots & x^2_n \\
\vdots & \vdots & \vdots & \ddots & \vdots \\
x^{n-1}_1 & x^{n-1}_2 & x^{n-1}_3 & \cdots & x^{n-1}_n
\end{array}
\right]$$

We call $V_n$ the \textit{Vandermonde matrix} of order n.\\

Claim:
$$ det  V_n = \prod_{1 \leq j \leq n} (x_j - x_i).$$



\item
\begin{eqnarray}\label{e1}
(a+b)^2 &=& a.a + a.b + b.a + b.b \\
&=& a^2 + ab + ba + b^2 \\
&=& a^2 + 2ab + b^2
\end{eqnarray}

\end{enumerate}
